    "# =============================================================================\n",
    "import os\n",
    "EQUIPAY_MODE = os.environ.get('EQUIPAY_MODE', 'FAST')  # FAST | FULL\n",
    "\n",
    "if EQUIPAY_MODE == 'FAST':\n",
    "    N_SAMPLES = 1000\n",
    "    N_BOOTSTRAP = 100\n",
    "    MAX_ITER = 200\n",
    "    N_ESTIMATORS = 50\n",
    "    PLOT_INLINE = False\n",
    "    print(\"⚡ Running in FAST mode: using samples, reduced bootstraps, and minimal plotting.\")\n",
    "else:\n",
