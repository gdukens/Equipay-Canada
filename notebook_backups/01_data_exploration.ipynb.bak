   "source": [
    "# Compute yearly wage stats via SQL with fallback to sample-based pandas computation\n",
    "try:\n",
    "    yearly_gap = store.sql('''\n",
    "        SELECT SURVYEAR AS year,\n",
    "               SUM(CASE WHEN GENDER = 1 THEN REAL_HRLYEARN * FINALWT END)/NULLIF(SUM(CASE WHEN GENDER = 1 THEN FINALWT END),0) AS male_mean,\n",
    "               SUM(CASE WHEN GENDER = 2 THEN REAL_HRLYEARN * FINALWT END)/NULLIF(SUM(CASE WHEN GENDER = 2 THEN FINALWT END),0) AS female_mean,\n",
    "               COUNT(*) AS n\n",
    "        FROM lfs_enriched\n",
    "        WHERE HRLYEARN > 0\n",
    "        GROUP BY SURVYEAR\n",
    "        ORDER BY SURVYEAR\n",
    "    ''')\n",
    "    yearly_gap['Gap (%)'] = (yearly_gap['male_mean'] - yearly_gap['female_mean']) / yearly_gap['male_mean'] * 100\n",
    "except Exception:\n",
    "    df_sample = get_sample_from_store(query='HRLYEARN > 0', limit=N_SAMPLES)\n",
    "    grouped = df_sample.groupby('SURVYEAR')\n",
    "    yearly_gap = grouped.apply(lambda x: pd.Series({\n",
    "        'male_mean': x.loc[x['GENDER']==1, 'REAL_HRLYEARN'].mean() if 'REAL_HRLYEARN' in x.columns else x.loc[x['GENDER']==1,'HRLYEARN'].mean(),\n",
    "        'female_mean': x.loc[x['GENDER']==2, 'REAL_HRLYEARN'].mean() if 'REAL_HRLYEARN' in x.columns else x.loc[x['GENDER']==2,'HRLYEARN'].mean(),\n",
    "        'n': len(x)\n",
    "    })).reset_index()\n",
    "    yearly_gap['Gap (%)'] = (yearly_gap['male_mean'] - yearly_gap['female_mean']) / yearly_gap['male_mean'] * 100\n",
    "\n",
    "print('Computing wage gaps by year (SQL-accelerated)...')\n"
   ]
