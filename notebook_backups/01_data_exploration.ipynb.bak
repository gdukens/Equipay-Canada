    "        COUNT(*) as total_rows,\n",
    "        SUM(CASE WHEN HRLYEARN IS NULL THEN 1 ELSE 0 END) as null_wages,\n",
    "        SUM(CASE WHEN HRLYEARN > 0 THEN 1 ELSE 0 END) as valid_wages\n",
    "    FROM lfs\n",
    "\"\"\")\n",
    "print(f\"Total observations: {quality['total_rows'].values[0]:,}\")\n",
