   "source": [
    "# =============================================================================\n",
    "# 🆕 MOTHERHOOD PENALTY ANALYSIS (AGYOWNK)\n",
    "# =============================================================================\n",
    "\"\"\"\n",
    "AGYOWNK: Age of youngest own child\n",
    "This is critical for analyzing the \"motherhood penalty\" in wages.\n",
    "\"\"\"\n",
    "\n",
    "print(\"📊 MOTHERHOOD PENALTY ANALYSIS\")\n",
    "print(\"=\" * 70)\n",
    "\n",
    "# Analyze wage gap by presence of children\n",
    "agyownk_df = store.query(\"\"\"\n",
    "    SELECT \n",
    "        CASE \n",
    "            WHEN AGYOWNK = 0 THEN 'No children'\n",
    "            WHEN AGYOWNK IN (1, 2) THEN 'Child under 3'\n",
    "            WHEN AGYOWNK IN (3, 4) THEN 'Child 3-12'\n",
    "            WHEN AGYOWNK IN (5, 6, 7) THEN 'Child 13+'\n",
    "            ELSE 'Unknown'\n",
    "        END as child_status,\n",
    "        GENDER,\n",
    "        AVG(REAL_HRLYEARN) as avg_wage,\n",
    "        SUM(FINALWT) as total_weight,\n",
    "        COUNT(*) as n\n",
    "    FROM lfs\n",
    "    WHERE REAL_HRLYEARN > 0 AND REAL_HRLYEARN < 200\n",
    "      AND AGYOWNK IS NOT NULL\n",
    "      AND AGE_6 IN (2, 3, 4)  -- Prime working age (25-54)\n",
    "    GROUP BY child_status, GENDER\n",
    "\"\"\")\n",
    "\n",
    "print(\"\\n--- Gender Gap by Parental Status (Ages 25-54) ---\\n\")\n",
    "print(f\"{'Parental Status':<20} {'Men':>12} {'Women':>12} {'Gap':>10} {'Penalty':>12}\")\n",
    "print(\"-\" * 70)\n",
    "\n",
    "# Get base wage (no children)\n",
    "base_male = agyownk_df[(agyownk_df['child_status'] == 'No children') & (agyownk_df['GENDER'] == 1)]['avg_wage'].values\n",
    "base_female = agyownk_df[(agyownk_df['child_status'] == 'No children') & (agyownk_df['GENDER'] == 2)]['avg_wage'].values\n",
    "\n",
    "for status in ['No children', 'Child under 3', 'Child 3-12', 'Child 13+']:\n",
    "    male = agyownk_df[(agyownk_df['child_status'] == status) & (agyownk_df['GENDER'] == 1)]\n",
    "    female = agyownk_df[(agyownk_df['child_status'] == status) & (agyownk_df['GENDER'] == 2)]\n",
    "    \n",
    "    if len(male) > 0 and len(female) > 0:\n",
    "        male_wage = male['avg_wage'].values[0]\n",
    "        female_wage = female['avg_wage'].values[0]\n",
    "        gap = (male_wage - female_wage) / male_wage * 100\n",
    "        \n",
    "        # Motherhood penalty (compared to childless women)\n",
    "        if len(base_female) > 0:\n",
    "            penalty = (base_female[0] - female_wage) / base_female[0] * 100\n",
    "            penalty_str = f\"{penalty:+.1f}%\"\n",
    "        else:\n",
    "            penalty_str = \"N/A\"\n",
    "        \n",
    "        print(f\"{status:<20} ${male_wage:>10.2f} ${female_wage:>10.2f} {gap:>8.1f}% {penalty_str:>12}\")\n",
    "\n",
    "print(\"\\n💡 KEY INSIGHT: Women with young children often earn less than\")\n",
    "print(\"   childless women (motherhood penalty), while men may earn MORE\")\n",
    "print(\"   with children (fatherhood premium).\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "1369a16e",
   "metadata": {},
   "outputs": [],
   "source": [
    "# =============================================================================\n",
    "# SQL-FIRST: Education / Occupation / Province Wage Comparisons\n",
    "# =============================================================================\n",
    "print(\"📊 SQL-first: Mean Real Wage by Education, Occupation, and Province\")\n",
    "\n",
    "# Education-level average real wage (weighted)\n",
    "educ_sql = \"\"\"\n",
    "SELECT EDUC,\n",
    "       SUM(REAL_HRLYEARN * FINALWT) / NULLIF(SUM(FINALWT), 0) AS mean_real_wage,\n",
    "       SUM(FINALWT) as total_weight,\n",
    "       COUNT(*) as n\n",
    "FROM lfs_enriched\n",
    "WHERE REAL_HRLYEARN > 0\n",
    "GROUP BY EDUC\n",
    "ORDER BY EDUC\n",
    "\"\"\"\n",
    "educ_df = store.sql(educ_sql)\n",
    "educ_df['label'] = educ_df['EDUC'].map(lambda c: EDUCATION_CODES.get(int(c), str(c))[:15])\n",
    "\n",
    "# Occupation-level average real wage (weighted)\n",
    "occ_sql = \"\"\"\n",
    "SELECT NOC_10 AS NOC_10,\n",
    "       SUM(REAL_HRLYEARN * FINALWT) / NULLIF(SUM(FINALWT), 0) AS mean_real_wage,\n",
    "       SUM(FINALWT) as total_weight,\n",
    "       COUNT(*) as n\n",
    "FROM lfs_enriched\n",
    "WHERE REAL_HRLYEARN > 0\n",
    "GROUP BY NOC_10\n",
    "ORDER BY mean_real_wage ASC\n",
    "\"\"\"\n",
    "occ_df = store.sql(occ_sql)\n",
    "occ_df['label'] = occ_df['NOC_10'].map(lambda c: NOC_10_CODES.get(int(c), str(c))[:25])\n",
    "\n",
    "# Province-level gender gap (weighted)\n",
    "prov_sql = \"\"\"\n",
    "SELECT PROV,\n",
    "       SUM(CASE WHEN GENDER = 1 THEN REAL_HRLYEARN * FINALWT END) /\n",
    "           NULLIF(SUM(CASE WHEN GENDER = 1 THEN FINALWT END), 0) AS male_wage,\n",
    "       SUM(CASE WHEN GENDER = 2 THEN REAL_HRLYEARN * FINALWT END) /\n",
    "           NULLIF(SUM(CASE WHEN GENDER = 2 THEN FINALWT END), 0) AS female_wage,\n",
    "       SUM(FINALWT) as total_weight\n",
    "FROM lfs_enriched\n",
    "WHERE REAL_HRLYEARN > 0\n",
    "GROUP BY PROV\n",
    "ORDER BY PROV\n",
    "\"\"\"\n",
    "prov_df = store.sql(prov_sql)\n",
    "prov_df['gap_pct'] = (prov_df['male_wage'] - prov_df['female_wage']) / prov_df['male_wage'] * 100\n",
    "prov_df['PROV_LABEL'] = prov_df['PROV'].map(lambda x: PROVINCE_CODES.get(int(x), str(x)))\n",
    "\n",
    "# Quick parity checks (small sample comparison with pandas df if available)\n",
    "if 'df' in globals():\n",
    "    # Education parity (small sample)\n",
    "    sample_years = sorted(df['SURVYEAR'].unique())[:3]\n",
    "    pandas_educ = (\n",
    "        df[df['SURVYEAR'].isin(sample_years) & (df['REAL_HRLYEARN'] > 0)]\n",
    "        .groupby('EDUC')\n",
    "        .apply(lambda x: pd.Series({\n",
    "            'mean_real_pandas': (x['REAL_HRLYEARN'] * x['FINALWT']).sum() / x['FINALWT'].sum()\n",
    "        }))\n",
    "        .reset_index()\n",
    "    )\n",
    "\n",
    "    merged_educ = educ_df.merge(pandas_educ, left_on='EDUC', right_on='EDUC', how='left')\n",
    "    if merged_educ['mean_real_pandas'].notna().any():\n",
    "        merged_educ['diff'] = (merged_educ['mean_real_pandas'] - merged_educ['mean_real_wage']).abs()\n",
    "        assert merged_educ['diff'].max() < 1e-6, 'Parity check failed for EDUC averages'\n",
    "        print('✓ EDUC parity check passed (sample years)')\n",
    "\n",
    "# Plot top/bottom occupations\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "plt.figure(figsize=(10, 6))\n",
    "plt.barh(occ_df['label'][:20], occ_df['mean_real_wage'][:20], color='teal')\n",
    "plt.title('Top 20 Occupations by Mean Real Wage (weighted)')\n",
    "plt.xlabel('Mean Real Wage (2010$)')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Plot province gaps\n",
    "plt.figure(figsize=(8, 6))\n",
    "plt.barh(prov_df['PROV_LABEL'], prov_df['gap_pct'], color='purple')\n",
    "plt.title('Gender Wage Gap by Province (Male - Female) % (weighted)')\n",
    "plt.xlabel('Gap (%)')\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]
  },
