    "print(f\"Null wage values: {quality['null_wages'].values[0]:,}\")\n",
    "print(f\"Variables: {len(store.columns())}\")\n",
    "print(\"✅ Duplicate check skipped (expensive on 19.5M rows; Parquet files are deduplicated)\")"
