    "ax.set_title('Log-Transformed (more symmetric)')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../reports/figures/wage_diagnostics.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(\"✅ Log-transformation improves normality substantially (Q-Q plot more linear).\")"
