   "source": [
    "# Vectorized: Gender composition by occupation (replace groupby.apply)\n",
    "if COLS.NOC_10 in df.columns:\n",
    "    gender_by_occ_vec = (df[gender_col] == 2).groupby(df[COLS.NOC_10]).mean().sort_values() * 100\n",
    "    # If legacy `gender_by_occ` exists, compare for parity\n",
    "    if 'gender_by_occ' in globals():\n",
    "        # Align indices\n",
    "        legacy = pd.Series(gender_by_occ.values, index=gender_by_occ.index)\n",
    "        merged_idx = legacy.index.intersection(gender_by_occ_vec.index)\n",
    "        assert np.allclose(legacy.loc[merged_idx].astype(float).values, gender_by_occ_vec.loc[merged_idx].astype(float).values, rtol=1e-6, equal_nan=True), 'Gender by occupation parity FAILED'\n",
    "        print('✓ gender_by_occ parity OK (legacy vs vectorized)')\n",
    "    # Replace / set canonical variable\n",
    "    gender_by_occ = gender_by_occ_vec\n",
    "    print(f\"✓ gender_by_occ computed (occupations: {len(gender_by_occ)})\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "276a6c40",
   "metadata": {},
   "outputs": [],
   "source": [
    "# SQL-first: Province gap table (single-step) — replaces manual pandas merge from `intersect`\n",
    "prov_gap_sql = \"\"\"\n",
    "SELECT PROV,\n",
    "       SUM(CASE WHEN GENDER = 1 THEN REAL_HRLYEARN * FINALWT END) / NULLIF(SUM(CASE WHEN GENDER = 1 THEN FINALWT END), 0) AS male_wage,\n",
    "       SUM(CASE WHEN GENDER = 2 THEN REAL_HRLYEARN * FINALWT END) / NULLIF(SUM(CASE WHEN GENDER = 2 THEN FINALWT END), 0) AS female_wage,\n",
    "       COUNT(*) AS n\n",
    "FROM lfs_enriched\n",
    "WHERE REAL_HRLYEARN > 0\n",
    "GROUP BY PROV\n",
    "ORDER BY PROV\n",
    "\"\"\"\n",
    "prov_gap_new = store.sql(prov_gap_sql)\n",
    "prov_gap_new['gap_pct'] = (prov_gap_new['male_wage'] - prov_gap_new['female_wage']) / prov_gap_new['male_wage'] * 100\n",
    "prov_gap_new['PROV_LABEL'] = prov_gap_new['PROV'].map(lambda x: PROVINCE_CODES.get(int(x), str(x)))\n",
    "\n",
    "# Parity check with older `intersect` construction (if available)\n",
    "if 'intersect' in globals():\n",
    "    male_w = intersect[intersect['GENDER'] == 1][['PROV', 'avg_wage']].rename(columns={'avg_wage': 'male_wage'})\n",
    "    female_w = intersect[intersect['GENDER'] == 2][['PROV', 'avg_wage']].rename(columns={'avg_wage': 'female_wage'})\n",
    "    old = male_w.merge(female_w, on='PROV')\n",
    "    old['gap_pct'] = (old['male_wage'] - old['female_wage']) / old['male_wage'] * 100\n",
    "    merged = prov_gap_new.merge(old, on='PROV', suffixes=('_sql', '_old'))\n",
    "    # Numeric parity within tight tolerance\n",
    "    if not (np.allclose(merged['male_wage_sql'].astype(float), merged['male_wage_old'].astype(float), rtol=1e-6, atol=1e-6) and\n",
    "            np.allclose(merged['female_wage_sql'].astype(float), merged['female_wage_old'].astype(float), rtol=1e-6, atol=1e-6)):\n",
    "        raise AssertionError('Prov gap parity failed between SQL and old pandas assembly')\n",
    "    print('✓ Provincial parity check OK')\n",
    "\n",
    "prov_gap = prov_gap_new.sort_values('gap_pct', ascending=False)\n",
    "print('\\n✓ prov_gap table computed via SQL (rows: {})'.format(len(prov_gap)))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "9ad62e34",
   "metadata": {},
   "outputs": [],
   "source": [
    "# =============================================================================\n",
    "# 🆕 REASON FOR PART-TIME WORK (WHYPT)\n",
    "# =============================================================================\n",
    "\"\"\"\n",
    "WHYPT: Reason for part-time work\n",
    "Critical for understanding involuntary part-time and its gender dimension.\n",
    "\"\"\"\n",
    "\n",
    "print(\"📊 REASON FOR PART-TIME WORK × GENDER\")\n",
    "print(\"=\" * 70)\n",
    "\n",
    "whypt_df = store.query(\"\"\"\n",
    "    SELECT WHYPT, GENDER,\n",
    "           AVG(REAL_HRLYEARN) as avg_wage,\n",
    "           SUM(FINALWT) as total_weight,\n",
    "           COUNT(*) as n\n",
    "    FROM lfs\n",
    "    WHERE REAL_HRLYEARN > 0 AND REAL_HRLYEARN < 200\n",
    "      AND FTPTMAIN = 2  -- Part-time workers only\n",
    "      AND WHYPT IS NOT NULL AND WHYPT > 0\n",
    "    GROUP BY WHYPT, GENDER\n",
    "\"\"\")\n",
    "\n",
    "whypt_labels = {\n",
    "    1: 'Own illness/disability',\n",
    "    2: 'Personal/family responsibilities',\n",
    "    3: 'Going to school',\n",
    "    4: 'Could only find part-time',\n",
    "    5: 'Did not want full-time',\n",
    "    6: 'Other reasons'\n",
    "}\n",
    "\n",
    "print(\"\\n--- Part-Time Workers by Reason ---\\n\")\n",
    "print(f\"{'Reason for Part-Time':<35} {'% Male':>10} {'% Female':>10}\")\n",
    "print(\"-\" * 55)\n",
    "\n",
    "# Calculate proportions\n",
    "total_male = whypt_df[whypt_df['GENDER'] == 1]['total_weight'].sum()\n",
    "total_female = whypt_df[whypt_df['GENDER'] == 2]['total_weight'].sum()\n",
    "\n",
    "for code, label in whypt_labels.items():\n",
    "    male = whypt_df[(whypt_df['WHYPT'] == code) & (whypt_df['GENDER'] == 1)]\n",
    "    female = whypt_df[(whypt_df['WHYPT'] == code) & (whypt_df['GENDER'] == 2)]\n",
    "    \n",
    "    male_pct = (male['total_weight'].sum() / total_male * 100) if total_male > 0 else 0\n",
    "    female_pct = (female['total_weight'].sum() / total_female * 100) if total_female > 0 else 0\n",
    "    \n",
    "    print(f\"{label:<35} {male_pct:>8.1f}% {female_pct:>8.1f}%\")\n",
    "\n",
    "print(\"\\n💡 KEY INSIGHT: Women are much more likely to work part-time due to\")\n",
    "print(\"   'personal/family responsibilities', reflecting unpaid care work burden.\")"
   ]
  },
  {
   "cell_type": "code",
