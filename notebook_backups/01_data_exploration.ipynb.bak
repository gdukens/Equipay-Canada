    "    N_BOOTSTRAP = 1000\n",
    "    MAX_ITER = 1000\n",
    "    N_ESTIMATORS = 200\n",
    "    PLOT_INLINE = True\n",
    "    print(\"🚀 Running in FULL mode: using all data and full computation for publication.\")\n"
