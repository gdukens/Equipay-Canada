   "source": [
    "# =============================================================================\n",
    "# WEIGHTED VS UNWEIGHTED STATISTICS (SQL-only, no in-memory merge)\n",
    "# =============================================================================\n",
    "print(\"📊 Comparing Weighted vs Unweighted Statistics — SQL first (single query)\")\n",
    "print(\"=\" * 60)\n",
    "print()\n",
    "\n",
    "comparison_sql = \"\"\"\n",
    "SELECT\n",
    "    SURVYEAR,\n",
    "    -- Weighted (population) estimates\n",
    "    SUM(CASE WHEN GENDER = 1 THEN HRLYEARN * FINALWT END) /\n",
    "        NULLIF(SUM(CASE WHEN GENDER = 1 THEN FINALWT END), 0) AS male_wage_wt,\n",
    "    SUM(CASE WHEN GENDER = 2 THEN HRLYEARN * FINALWT END) /\n",
    "        NULLIF(SUM(CASE WHEN GENDER = 2 THEN FINALWT END), 0) AS female_wage_wt,\n",
    "    -- Unweighted (sample) estimates\n",
    "    AVG(CASE WHEN GENDER = 1 THEN HRLYEARN END) AS male_wage_unwt,\n",
    "    AVG(CASE WHEN GENDER = 2 THEN HRLYEARN END) AS female_wage_unwt\n",
    "FROM lfs_enriched\n",
    "WHERE HRLYEARN > 0\n",
    "GROUP BY SURVYEAR\n",
    "ORDER BY SURVYEAR\n",
    "\"\"\"\n",
    "\n",
    "cmp = store.sql(comparison_sql)\n",
    "cmp['gap_pct_wt'] = (cmp['male_wage_wt'] - cmp['female_wage_wt']) / cmp['male_wage_wt'] * 100\n",
    "cmp['gap_pct_unwt'] = (cmp['male_wage_unwt'] - cmp['female_wage_unwt']) / cmp['male_wage_unwt'] * 100\n",
    "cmp['gap_diff'] = cmp['gap_pct_wt'] - cmp['gap_pct_unwt']\n",
    "\n",
    "print(\"\\nDifference (weighted - unweighted):\")\n",
    "print(cmp[['SURVYEAR', 'gap_pct_unwt', 'gap_pct_wt', 'gap_diff']].to_string(index=False))\n",
    "\n",
    "print(\"\\n✅ All subsequent analyses will use WEIGHTED statistics for valid population inference (computed in SQL).\")"
   ]
  },
