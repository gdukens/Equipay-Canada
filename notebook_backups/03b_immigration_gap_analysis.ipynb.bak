   "source": [
    "## 1. Data Loading & Immigration Status Overview"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "0873ee59",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================================\n",
    "# LOAD DATA VIA EquiPayDataStore\n",
    "# ============================================================================\n",
    "\n",
    "store = EquiPayDataStore()\n",
    "\n",
    "# Get immigration wage gap using the generalized method\n",
    "immig_gap = store.immigration_gap(by=['SURVYEAR'])\n",
    "\n",
    "print(\"Immigration Wage Gap by Year:\")\n",
    "print(\"=\" * 60)\n",
    "display(immig_gap.round(2))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "deb9d9c9",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================================\n",
    "# IMMIGRATION GAP BY PROVINCE\n",
    "# ============================================================================\n",
    "\n",
    "immig_gap_prov = store.wage_gap(\n",
    "    group_column='IMMIG',\n",
    "    reference_value=1,\n",
    "    comparison_value=2,\n",
    "    by=['PROV'],\n",
    "    reference_label='Canadian-born',\n",
    "    comparison_label='Immigrant'\n",
    ")\n",
    "\n",
    "# Add province names\n",
    "immig_gap_prov['province'] = immig_gap_prov['PROV'].map(PROVINCE_CODES)\n",
    "\n",
    "# Visualize\n",
    "fig, ax = plt.subplots(figsize=(10, 6))\n",
    "immig_gap_prov_sorted = immig_gap_prov.sort_values('gap_pct', ascending=True)\n",
    "colors = ['#e74c3c' if x > 0 else '#27ae60' for x in immig_gap_prov_sorted['gap_pct']]\n",
    "\n",
    "ax.barh(immig_gap_prov_sorted['province'], immig_gap_prov_sorted['gap_pct'], color=colors)\n",
    "ax.axvline(x=0, color='black', linewidth=0.5)\n",
    "ax.set_xlabel('Wage Gap (%) - Canadian-born vs Immigrant')\n",
    "ax.set_title('Immigration Wage Gap by Province\\n(Positive = Canadian-born earn more)')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../reports/figures/immigration_gap_by_province.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(\"\\n✓ Figure saved to reports/figures/immigration_gap_by_province.png\")"
   ]
  },
