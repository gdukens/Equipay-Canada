   "source": [
    "## 2. Credential Recognition Analysis\n",
    "\n",
    "One key hypothesis for immigrant wage gaps is **differential returns to education** - immigrants may not receive the same wage premium for their education as Canadian-born workers due to credential recognition barriers."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "8c8e2667",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================================\n",
    "# RETURNS TO EDUCATION BY IMMIGRATION STATUS\n",
    "# ============================================================================\n",
    "\n",
    "# Get wage gap by education level for immigrants vs Canadian-born\n",
    "immig_gap_educ = store.wage_gap(\n",
    "    group_column='IMMIG',\n",
    "    reference_value=1,\n",
    "    comparison_value=2,\n",
    "    by=['EDUC'],\n",
    "    reference_label='Canadian-born',\n",
    "    comparison_label='Immigrant'\n",
    ")\n",
    "\n",
    "immig_gap_educ['education'] = immig_gap_educ['EDUC'].map(EDUCATION_CODES)\n",
    "\n",
    "# Visualize\n",
    "fig, ax = plt.subplots(figsize=(12, 6))\n",
    "x = range(len(immig_gap_educ))\n",
    "width = 0.35\n",
    "\n",
    "ax.bar([i - width/2 for i in x], immig_gap_educ['reference_mean'], width, \n",
    "       label='Canadian-born', color='#3498db')\n",
    "ax.bar([i + width/2 for i in x], immig_gap_educ['comparison_mean'], width, \n",
    "       label='Immigrant', color='#e74c3c')\n",
    "\n",
    "ax.set_xlabel('Education Level')\n",
    "ax.set_ylabel('Log Hourly Wage (Weighted Mean)')\n",
    "ax.set_title('Returns to Education: Canadian-born vs Immigrant Workers')\n",
    "ax.set_xticks(x)\n",
    "ax.set_xticklabels(immig_gap_educ['education'], rotation=45, ha='right')\n",
    "ax.legend()\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../reports/figures/credential_recognition_gap.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(\"\\nKey Insight: If the gap widens at higher education levels,\")\n",
    "print(\"this suggests credential recognition barriers for immigrants.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "38f51a6c",
   "metadata": {},
   "source": [
    "## 3. Blinder-Oaxaca Decomposition for Immigration Gap\n",
    "\n",
    "Apply the same decomposition methodology used for gender to understand what portion of the immigrant wage gap is explained by observable characteristics."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "188d7292",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================================\n",
    "# OAXACA-BLINDER DECOMPOSITION FOR IMMIGRATION\n",
    "# ============================================================================\n",
    "\n",
    "# Sample data for decomposition\n",
    "sample = store.sample(n=50000, where=\"HRLYEARN > 0 AND IMMIG IN (1, 2)\")\n",
    "\n",
    "# Create binary indicator\n",
    "sample['is_canadian_born'] = (sample['IMMIG'] == 1).astype(int)\n",
    "\n",
    "# Prepare features for decomposition\n",
    "features = ['EDUC', 'NOC_10', 'PROV', 'AGE_12', 'GENDER', 'FTPTMAIN', 'UNION']\n",
    "\n",
    "# Initialize decomposition with immigration as the group variable\n",
    "ob_decomp = OaxacaBlinderDecomposition(\n",
    "    group_col='is_canadian_born',\n",
    "    features=features,\n",
    "    target='LOG_REAL_HRLYEARN',\n",
    "    weight_col='FINALWT'\n",
    ")\n",
    "\n",
    "# Run decomposition\n",
    "result = ob_decomp.fit(sample)\n",
    "\n",
    "print(\"\\nOaxaca-Blinder Decomposition: Immigration Wage Gap\")\n",
    "print(\"=\" * 60)\n",
    "print(f\"Reference Group: Canadian-born\")\n",
    "print(f\"Comparison Group: Immigrant\")\n",
    "print(f\"\\nTotal Gap: {result.total_gap:.3f} log points ({result.total_gap * 100:.1f}%)\")\n",
    "print(f\"Explained: {result.explained:.3f} ({result.explained / result.total_gap * 100:.1f}%)\")\n",
    "print(f\"Unexplained: {result.unexplained:.3f} ({result.unexplained / result.total_gap * 100:.1f}%)\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "d02c5ccd",
   "metadata": {},
   "source": [
    "## 4. Intersectional Analysis: Immigration × Gender\n",
    "\n",
    "Do immigrant women face a **compound penalty** beyond what would be expected from the sum of immigration and gender penalties?"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "4e42349e",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================================\n",
    "# INTERSECTIONAL ANALYSIS: IMMIGRATION × GENDER\n",
    "# ============================================================================\n",
    "\n",
    "# Get intersectional wage gap\n",
    "intersect_gap = store.sql(\"\"\"\n",
    "    SELECT \n",
    "        GENDER,\n",
    "        IMMIG,\n",
    "        SUM(LOG_REAL_HRLYEARN * FINALWT) / SUM(FINALWT) as mean_log_wage,\n",
    "        SUM(FINALWT) as population,\n",
    "        COUNT(*) as n\n",
    "    FROM lfs\n",
    "    WHERE HRLYEARN > 0 AND GENDER IN (1, 2) AND IMMIG IN (1, 2)\n",
    "    GROUP BY GENDER, IMMIG\n",
    "\"\"\")\n",
    "\n",
    "# Pivot for visualization\n",
    "intersect_gap['gender_label'] = intersect_gap['GENDER'].map({1: 'Male', 2: 'Female'})\n",
    "intersect_gap['immig_label'] = intersect_gap['IMMIG'].map({1: 'Canadian-born', 2: 'Immigrant'})\n",
    "\n",
    "# Create heatmap\n",
    "pivot = intersect_gap.pivot(index='immig_label', columns='gender_label', values='mean_log_wage')\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(8, 6))\n",
    "sns.heatmap(pivot, annot=True, fmt='.3f', cmap='RdYlGn', center=pivot.values.mean(), ax=ax)\n",
    "ax.set_title('Mean Log Wage by Gender × Immigration Status\\n(Higher = Better)')\n",
    "ax.set_xlabel('Gender')\n",
    "ax.set_ylabel('Immigration Status')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../reports/figures/intersectional_gender_immigration.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "# Calculate compound penalty\n",
    "canadian_male = pivot.loc['Canadian-born', 'Male']\n",
    "canadian_female = pivot.loc['Canadian-born', 'Female']\n",
    "immigrant_male = pivot.loc['Immigrant', 'Male']\n",
    "immigrant_female = pivot.loc['Immigrant', 'Female']\n",
    "\n",
    "gender_penalty = canadian_male - canadian_female\n",
    "immigration_penalty = canadian_male - immigrant_male\n",
    "expected_penalty = gender_penalty + immigration_penalty\n",
    "actual_penalty = canadian_male - immigrant_female\n",
    "compound_effect = actual_penalty - expected_penalty\n",
    "\n",
    "print(\"\\nIntersectional Analysis:\")\n",
    "print(\"=\" * 50)\n",
    "print(f\"Gender penalty (Cdn-born M vs F): {gender_penalty:.3f} ({gender_penalty*100:.1f}%)\")\n",
    "print(f\"Immigration penalty (Cdn M vs Immig M): {immigration_penalty:.3f} ({immigration_penalty*100:.1f}%)\")\n",
    "print(f\"Expected combined penalty: {expected_penalty:.3f} ({expected_penalty*100:.1f}%)\")\n",
    "print(f\"Actual penalty (Cdn M vs Immig F): {actual_penalty:.3f} ({actual_penalty*100:.1f}%)\")\n",
    "print(f\"\\nCompound/Interaction effect: {compound_effect:.3f} ({compound_effect*100:.1f}%)\")\n",
    "if compound_effect > 0.01:\n",
    "    print(\"⚠️  Evidence of compound disadvantage for immigrant women\")\n",
    "elif compound_effect < -0.01:\n",
    "    print(\"✓ Penalties are less than additive\")\n",
    "else:\n",
    "    print(\"✓ Penalties appear roughly additive\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "70a107c2",
   "metadata": {},
   "source": [
    "## 5. Time Series: Immigration Gap Trends\n",
    "\n",
    "How has the immigrant wage gap evolved over time?"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "9b00c914",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================================\n",
    "# IMMIGRATION GAP TIME SERIES\n",
    "# ============================================================================\n",
    "\n",
    "from src.time_series import WageGapTimeSeriesAnalyzer\n",
    "\n",
    "# Get yearly data\n",
    "yearly_data = store.sql(\"\"\"\n",
    "    SELECT \n",
    "        SURVYEAR as year,\n",
    "        IMMIG,\n",
    "        SUM(REAL_HRLYEARN * FINALWT) / SUM(FINALWT) as mean_wage\n",
    "    FROM lfs\n",
    "    WHERE HRLYEARN > 0 AND IMMIG IN (1, 2)\n",
    "    GROUP BY SURVYEAR, IMMIG\n",
    "    ORDER BY SURVYEAR, IMMIG\n",
    "\"\"\")\n",
    "\n",
    "# Initialize time series analyzer for immigration\n",
    "ts_analyzer = WageGapTimeSeriesAnalyzer(\n",
    "    yearly_data,\n",
    "    date_column='year',\n",
    "    wage_column='mean_wage',\n",
    "    group_column='IMMIG',\n",
    "    reference_value=1,\n",
    "    comparison_value=2,\n",
    "    reference_label='Canadian-born',\n",
    "    comparison_label='Immigrant'\n",
    ")\n",
    "\n",
    "# Plot the trend\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# Left: Wage levels\n",
    "ax1 = axes[0]\n",
    "ax1.plot(ts_analyzer.ts_data['year'], ts_analyzer.ts_data['reference_wage'], \n",
    "         'b-o', label='Canadian-born', linewidth=2, markersize=6)\n",
    "ax1.plot(ts_analyzer.ts_data['year'], ts_analyzer.ts_data['comparison_wage'], \n",
    "         'r-s', label='Immigrant', linewidth=2, markersize=6)\n",
    "ax1.set_xlabel('Year')\n",
    "ax1.set_ylabel('Real Hourly Wage ($2010)')\n",
    "ax1.set_title('Wage Trends by Immigration Status')\n",
    "ax1.legend()\n",
    "ax1.grid(True, alpha=0.3)\n",
    "\n",
    "# Right: Wage gap\n",
    "ax2 = axes[1]\n",
    "ax2.plot(ts_analyzer.ts_data['year'], ts_analyzer.ts_data['wage_gap'], \n",
    "         'g-^', linewidth=2, markersize=6)\n",
    "ax2.axhline(y=0, color='black', linestyle='--', alpha=0.5)\n",
    "ax2.fill_between(ts_analyzer.ts_data['year'], 0, ts_analyzer.ts_data['wage_gap'], \n",
    "                 alpha=0.3, color='green')\n",
    "ax2.set_xlabel('Year')\n",
    "ax2.set_ylabel('Wage Gap (%)')\n",
    "ax2.set_title('Immigration Wage Gap Over Time')\n",
    "ax2.grid(True, alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../reports/figures/immigration_gap_timeseries.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
