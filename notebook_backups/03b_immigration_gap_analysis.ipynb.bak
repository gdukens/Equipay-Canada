    "print(\"✓ Libraries loaded successfully\")\n",
    "print(f\"✓ Analysis period: {DATA_SCOPE_START}-{DATA_SCOPE_END}\")\n",
    "print(f\"✓ Equity Dimension: {IMMIG_DIM.description}\")\n",
    "print(f\"  Reference: {IMMIG_DIM.reference_label} (code {IMMIG_DIM.reference_value})\")\n",
    "print(f\"  Comparison: {IMMIG_DIM.comparison_label} (code {IMMIG_DIM.comparison_value})\")\n",
    "print(f\"  Legal basis: {IMMIG_DIM.legal_basis}\")"
   ]
