# EquiPay Canada Environment Configuration
# Copy this file to .env and update values as needed

# =============================================================================
# Application Settings
# =============================================================================
APP_NAME=EquiPay Canada
APP_VERSION=1.0.0
ENVIRONMENT=development

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/equipay.log

# =============================================================================
# Data Paths
# =============================================================================
DATA_PATH=data/
RAW_DATA_PATH=data/raw/
PROCESSED_DATA_PATH=data/processed/
MODEL_PATH=models/
REPORTS_PATH=reports/

# =============================================================================
# API Settings
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=4

# =============================================================================
# Dashboard Settings
# =============================================================================
STREAMLIT_HOST=0.0.0.0
STREAMLIT_PORT=8501

# =============================================================================
# Model Settings
# =============================================================================
MODEL_RANDOM_STATE=42
MODEL_TEST_SIZE=0.2
MODEL_CV_FOLDS=5

# =============================================================================
# Statistics Canada (for data download - optional)
# =============================================================================
# STATCAN_API_KEY=your_api_key_here

# =============================================================================
# Database (if using for persistence - optional)
# =============================================================================
# DATABASE_URL=postgresql://user:password@localhost:5432/equipay
# REDIS_URL=redis://localhost:6379/0
